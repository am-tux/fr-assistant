# FedRAMP Tracker - Git Ignore

# ⚠️  SECRETS AND TOKENS - NEVER COMMIT THESE ⚠️
# Environment files that may contain GITHUB_TOKEN
.env
.env.*
.envrc
*.env
env.sh
setenv.sh

# Token files
.token
*.token
token.txt
secrets.*
.secrets
credentials.*
.credentials

# Config files with hardcoded tokens (use environment variables instead!)
config.local.yaml
config.*.yaml
!config.yaml  # Allow the template config.yaml

# Backup files that might contain secrets
*.bak
*.backup
*.old
*.orig
*~

# User preferences
.tracker-config

# Downloaded repositories (cloned from GitHub)
repos/

# Generated reports
reports/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
