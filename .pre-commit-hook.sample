#!/bin/bash
# Pre-commit hook to prevent committing GitHub tokens
# To enable this hook:
#   cp .pre-commit-hook.sample .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit

# Color codes
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Check for common token patterns in staged files
if git diff --cached --name-only | xargs grep -E "ghp_[a-zA-Z0-9]{36}" 2>/dev/null; then
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}⚠️  COMMIT BLOCKED: GitHub Token Detected!${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo -e "${YELLOW}A GitHub personal access token (ghp_...) was found in staged files.${NC}"
    echo ""
    echo "What to do:"
    echo "  1. Remove the token from your files"
    echo "  2. Use environment variables instead: export GITHUB_TOKEN=your_token"
    echo "  3. See SECURITY.md for best practices"
    echo ""
    echo "To bypass this check (NOT recommended):"
    echo "  git commit --no-verify"
    echo ""
    exit 1
fi

# Check for other suspicious patterns
if git diff --cached --name-only | xargs grep -iE "(github_token|gh_token).*=.*['\"][a-zA-Z0-9_-]{20,}" 2>/dev/null; then
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${YELLOW}⚠️  WARNING: Possible hardcoded token detected${NC}"
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo "Found what looks like a hardcoded token assignment."
    echo "Please verify this is safe before committing."
    echo ""
    echo "See SECURITY.md for token best practices."
    echo ""
    read -p "Continue with commit? (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 1
    fi
fi

# Warn if committing .env files (should be gitignored)
if git diff --cached --name-only | grep -E "\\.env$|\\.env\\." 2>/dev/null; then
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${YELLOW}⚠️  WARNING: .env file being committed${NC}"
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo ".env files often contain secrets and should not be committed."
    echo "Consider adding them to .gitignore."
    echo ""
    read -p "Are you sure you want to commit this? (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 1
    fi
fi

# All checks passed
exit 0
